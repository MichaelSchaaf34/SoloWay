# Copy to `.env` in this folder for local / phone-on-LAN testing.
# Find your PC IP: Windows `ipconfig` → IPv4 (e.g. 192.168.1.42)
#
# When opening the app on your phone at http://YOUR_IP:3000, the API URL must
# point to your PC — not localhost (that would be the phone itself).
#
# VITE_API_URL=http://192.168.1.42:3001/api/v1
