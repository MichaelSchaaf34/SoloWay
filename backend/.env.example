NODE_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Supabase / PostgreSQL
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
DATABASE_URL=postgresql://replace-me
REDIS_URL=redis://localhost:6379

# Production TLS verification for Postgres. Download the CA certificate from
# Supabase (Project Settings -> Database -> SSL certificate) and paste it here
# either as raw PEM with \n-escaped newlines, or base64-encoded.
# DATABASE_CA_CERT=

# Log verbosity: trace|debug|info|warn|error. Defaults: debug (dev), info (prod).
# LOG_LEVEL=info

# Optional: Sentry error monitoring (backend project DSN from sentry.io).
# Leave unset to disable.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Use separate, randomly generated secrets (at least 32 bytes each).
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Transactional auth email. In Resend test mode, register using your
# Resend account email as the recipient.
RESEND_API_KEY=re_test_replace_me
EMAIL_FROM=SoloWay <onboarding@resend.dev>

# Stripe test mode only until the launch checklist is complete.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CONNECT_COUNTRY=US
STRIPE_DEFAULT_COMMISSION_BPS=1500

# Twilio SMS for QR Buddy guest verification. Required in production.
# Leave unset in development: codes are printed to the server console instead.
# TWILIO_ACCOUNT_SID=ACreplace_me
# TWILIO_AUTH_TOKEN=replace-me
# TWILIO_FROM_NUMBER=+15551234567

# Optional: powers "Happening in {city}" on destination pages.
# Free key from https://developer.ticketmaster.com — leave unset to hide the section.
# TICKETMASTER_API_KEY=replace-me

# Phone on the same Wi-Fi:
# APP_BASE_URL=http://YOUR_PC_IP:3000
# CORS_ORIGIN=http://localhost:3000,http://YOUR_PC_IP:3000
